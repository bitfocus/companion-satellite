{
	"extends": "@tsconfig/node24/tsconfig.json",
	"include": ["**/*.ts", "**/*.cts", "**/*.mts"],
	"compilerOptions": {
		"rootDir": "./",
		"paths": {
			"*": ["./node_modules/*"],
		},
		"types": ["node"],
		"lib": ["dom"],
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"declaration": true,
		"esModuleInterop": true,
		"noEmit": true,
		"allowImportingTsExtensions": true
	}
}
